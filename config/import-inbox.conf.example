# Copy to config/import-inbox.conf and adjust if needed.
# Files dropped here (via LocalSend from Ray-Ban Meta glasses) are auto-ingested.

IMPORT_INBOX="/home/ajlennon/LocalSend/rides-imports"
POLL_SECONDS=10
STABLE_CHECKS=3
STABLE_INTERVAL=2

# Notes appended to ingest-incident.sh for auto-imported clips
IMPORT_NOTES="auto-import from glasses inbox"

# After ingest (source moved to rides-imports/done/), upload PUBLISH.mp4 to YouTube as private.
AUTO_YOUTUBE_UPLOAD=true

# Commit *_UPLOAD.json + map GeoJSON and push to main (triggers GitHub Pages deploy).
AUTO_PUBLISH_MAP=true
